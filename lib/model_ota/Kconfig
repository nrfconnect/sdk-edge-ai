menuconfig MODEL_OTA
	bool "Model-only OTA update PoC (Neuton, linked partition image)"
	depends on FLASH && FLASH_MAP && CRC
	help
	  Proof-of-concept library that loads and validates a Neuton NN model from a dedicated
	  flash partition at runtime, independently of the application image, and without relying
	  on MCUboot for integrity checking or transport. The model is built as a self-contained,
	  linked partition image (the compiled nrf_edgeai_model_neuton_t descriptor and its data
	  linked AT the partition base, with a header holding a DIRECT pointer to the descriptor).
	  Model pointers are used directly in the memory-mapped partition (XIP) - there is no
	  RAM-copy loading mode. Enable CONFIG_FLASH, CONFIG_FLASH_MAP and CONFIG_CRC in the
	  application's prj.conf.

if MODEL_OTA

config MODEL_OTA_NEUTON
	bool "Enable the Neuton model image loader"
	depends on NRF_EDGEAI
	help
	  Builds model_image_neuton.c and model_image_load_neuton(). OTA-wired models are compiled
	  via model_ota_neuton_wire(), which configure_file()s lib/model_ota/src/model_ota_neuton_wired.c.in
	  into a per-model wired translation unit (includes generated nrf_edgeai_user_model.c and
	  defines nrf_edgeai_load_user_model_<SOLUTION_ID>()), then drops each wired model's payload from its static library by archive-scoped linker /DISCARD/ rules.
	  Build-time macro contract: model_ota_stub_macros.h.
	  See lib/model_ota/cmake/model_ota_neuton_image.cmake,
	  lib/model_ota/cmake/model_ota_neuton.cmake and include/model_ota/model_image.h.

config MODEL_OTA_AXON
	bool "Enable the Axon model image loader"
	depends on NRF_AXON
	help
	  Builds model_image_axon.c and model_image_load_axon(). Pure Axon models are built as
	  self-contained partition images and wired to the application with one
	  model_ota_axon_model() declaration. See lib/model_ota/cmake/model_ota_axon.cmake and
	  include/model_ota/model_image.h.

config MODEL_OTA_LOG_LEVEL
	int "Log level for the model_image module"
	default 3
	range 0 4
	help
	  0 = off, 1 = err, 2 = wrn, 3 = inf, 4 = dbg.

endif # MODEL_OTA
