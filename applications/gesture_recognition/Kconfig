source "Kconfig.zephyr"

config LED_NOTIFICATION_BLINK
	bool "Notification LED blink on event only"
	help
	  When enabled, the LED blinks a few times on state changes
	  (BLE connect/disconnect, mode switch via button) and then stays
	  off until the next event. This reduces current consumption.
	  When disabled (default), the status LED smoothly pulses using
	  PWM brightness changes driven by a periodic timer.

config DATA_COLLECTION_MODE
	bool "Enable Data Collection Mode (no inference run)"

choice NRF_EDGEAI_GESTURE_RECOGNITION_MODEL
	prompt "Edge AI model backend"
	default NRF_EDGEAI_GESTURE_RECOGNITION_MODEL_AXON if SOC_NRF54LM20B
	default NRF_EDGEAI_GESTURE_RECOGNITION_MODEL_NEUTON
	help
	  Select which model implementation to use. Axon (NPU) is only available
	  on nRF54L20 (nrf54lm20b). Other boards use Neuton (CPU).

config NRF_EDGEAI_GESTURE_RECOGNITION_MODEL_NEUTON
	bool "Neuton (CPU)"
	help
	  Use the Neuton model. Works on all supported boards.

config NRF_EDGEAI_GESTURE_RECOGNITION_MODEL_AXON
	bool "Axon (NPU)"
	depends on SOC_NRF54LM20B
	select NRF_AXON
	help
	  Use the Axon model. Only available on Axon-enabled devices.

endchoice

choice BLE_MODE
	prompt "BLE mode"
	default BLE_MODE_HID if !DATA_COLLECTION_MODE
	default BLE_MODE_NUS if DATA_COLLECTION_MODE

config BLE_MODE_NONE
	bool "No BLE"
	help
	  Disable Bluetooth. Inference results and data collection use serial only.

config BLE_MODE_HID
	bool "BLE HID (keyboard emulation)"
	depends on !DATA_COLLECTION_MODE
	depends on BT
	select BT_HIDS
	select BT_DIS
	select BT_DIS_PNP
	select BT_BAS
	help
	  Use BLE HID for gesture-to-keyboard mapping (inference mode).

config BLE_MODE_NUS
	bool "BLE NUS (Nordic UART Service)"
	depends on DATA_COLLECTION_MODE
	depends on BT
	select BT_NUS
	select BT_DIS
	select BT_DIS_PNP
	select BT_BAS
	help
	  Forward raw IMU samples over Nordic UART Service. A second development
	  kit running the Bluetooth Central UART sample is needed to receive
	  the data.

config BLE_MODE_GATT_CUSTOM
	bool "BLE GATT (custom GATT service)"
	depends on !DATA_COLLECTION_MODE
	depends on BT
	select BT_BAS
	select BT_DIS
	select BT_DIS_PNP
	help
	  Use custom GATT service to send inference results (class_label,probability).

endchoice

config IMU_FIFO_BATCH
	bool "Use BMI270 FIFO watermark batch mode"
	depends on BMI270_STREAM
	depends on !DATA_COLLECTION_MODE
	help
	  When enabled, the IMU module uses the BMI270 FIFO with the Zephyr
	  sensor stream (RTIO) API. Samples accumulate in the FIFO and the CPU
	  wakes only on the watermark interrupt, reads the whole batch at once,
	  and feeds each sample to inference. This greatly reduces wake-ups
	  compared to per-sample data-ready interrupts or polling.

choice BT_HIDS_DEFAULT_PERM
	default BT_HIDS_DEFAULT_PERM_RW_ENCRYPT if BLE_MODE_HID
endchoice
