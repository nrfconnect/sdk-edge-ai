menu "Person detection application"

config SCORE_THRESHOLD
	int "Model score threshold, in per mille"
	range 0 1000
	help
	  The confidence score threshold for each person detection.
	  Detections with confidence scores below this threshold are filtered out.

config IOU_THRESHOLD
	int "Boxes IoU threshold, in per mille"
	range 0 1000
	help
	  The Intersection-over-Union threshold for Non-Maximum Suppression (NMS).
	  Used to eliminate overlapping bounding boxes from multiple detections of the same person.

config PERSON_DET_MODEL_IN_PARTITION
	bool "Store person_det model in a dedicated flash partition"
	default y
	select NRF_AXON_MODEL_PARTITION
	help
	  Place the person_det Axon model in axon_model_partition instead of
	  linking it into the application image. A partition image is merged into
	  the final HEX file at build time.

config ARDUCAM_MEGA
	bool
	select EXPERIMENTAL
	default y
	help
	  [Experimental]

endmenu

source "Kconfig.zephyr"
