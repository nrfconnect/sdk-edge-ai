menu "Wakeword and Keyword Spotting application"

choice APP_MODE
	prompt "Application mode"
	default APP_MODE_WW_GATED_KWS

config APP_MODE_WW_GATED_KWS
	bool "Wakeword-gated keyword spotting mode"
	help
	  Run keyword spotting model only after wakeword was detected. After configurable duration
	  without any keyword spotted switch back to wakeword detection.

config APP_MODE_WW_ONLY
	bool "Wakeword detection only mode"
	help
	  Run wakeword detection continuously without switching to keyword spotting.

config APP_MODE_KWS_ONLY
	bool "Keyword spotting only mode"
	help
	  Run keyword spotting continuously without the need to detect wakeword first.

endchoice

config WW_PROBABILITY_THRESHOLD
	int "Wakeword probability threshold"
	range 0 1000
	default 990
	help
	   Probability threshold for wakeword detection model. The value is expressed in units of
	   1/1000.

config WW_HISTORY_SIZE
	int "Size of wakeword predictions history"
	range 1 32
	default 20
	help
	  Size of history of previous results from wakeword detection model. Each entry corresponds
	  to 30 milliseconds of past audio.

config WW_COUNT_THRESHOLD
	int "Threshold for wakeword detection from predictions history"
	range 1 WW_HISTORY_SIZE
	default 15
	help
	  Number of predictions above threshold in predictions history required to confirm wakeword
	  detection.

config KWS_PERIOD_MS
	int "Length of keyword spotting window in wakeword-gated mode"
	default 3000

config KWS_EMA_ALPHA
	int "Exponential moving average coefficient for class probability"
	range 0 1000
	default 120
	help
	  Coefficient for new entries in exponential moving average calculation for average class
	  probability. The value is expressed in units of 1/1000.

config APP_MODEL_OTA
	bool "Load wakeword/keyword-spotting models from flash (model-only OTA)"
	default y
	select FLASH
	select FLASH_MAP
	select CRC
	select MODEL_OTA
	select MODEL_OTA_AXON
	help
	  When enabled (the default), this application does not ship compiled-in wakeword and
	  keyword-spotting models: at boot, each is loaded and validated from its own dedicated
	  flash partition instead - model_storage_ww and model_storage_kws respectively (see
	  boards/*.overlay and doc/libraries/model_ota.rst) - independently of the application
	  image. Disable this to restore this application's original pre-model-OTA behavior:
	  both models are compiled directly into the application image.

if APP_MODEL_OTA

config APP_WW_PERSISTENT_VARS_SIZE
	int "Size (in int32_t elements) of the WW model's persistent_vars RAM array"
	default 1160
	help
	  Must match the axon_model_<name>_persistent_vars[] array size in the WW model's own
	  generated header (src/ww/nrf_edgeai_generated/nrf_edgeai_user_model_axon.h) - update
	  this alongside that header whenever the WW model is regenerated.

config APP_KWS_PERSISTENT_VARS_SIZE
	int "Size (in int32_t elements) of the KWS model's persistent_vars RAM array"
	default 6648
	help
	  Must match the axon_model_<name>_persistent_vars[] array size in the KWS model's own
	  generated header (src/kws/nrf_edgeai_generated/nrf_edgeai_user_model_axon.h) - update
	  this alongside that header whenever the KWS model is regenerated.

endif # APP_MODEL_OTA

config MODELS_OBSERVABILITY
	bool "Edge AI observability metrics"
	depends on NRF_EDGEAI_OBSV
	depends on NRF_EDGEAI_OBSV_MEMFAULT
	depends on NRF_EDGEAI_OBSV_METRIC_PROBS_DISTRIBUTION
	depends on NRF_EDGEAI_OBSV_METRIC_TRANSITION_MATRIX || APP_MODE_WW_ONLY
	depends on NRF_EDGEAI_OBSV_MEMFAULT_MAX_CONTEXTS >= 2 || !APP_MODE_WW_GATED_KWS
	help
	  Wire observability into the bundled models. Each model file owns its observability context
	  and Memfault transport binding.

if MODELS_OBSERVABILITY

config MODELS_OBSERVABILITY_MDS
	def_bool y
	depends on BT_MDS
	depends on BT_SMP
	depends on NRF_EDGEAI_OBSV_MEMFAULT_AUTO_COLLECT

endif # MODELS_OBSERVABILITY

endmenu

source "Kconfig.zephyr"
