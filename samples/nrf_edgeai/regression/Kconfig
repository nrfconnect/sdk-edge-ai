menu "nRF Edge AI Regression sample"

choice NRF_EDGEAI_REGRESSION_MODEL
	prompt "Regression model backend"
	default NRF_EDGEAI_REGRESSION_MODEL_AXON if SOC_NRF54LM20B
	default NRF_EDGEAI_REGRESSION_MODEL_NEUTON
	help
	  Select which model implementation to use for the air quality regression sample.
	  Neuton runs on CPU; Axon uses the NPU and is only available on nRF54L20 (nrf54lm20b).

config NRF_EDGEAI_REGRESSION_MODEL_NEUTON
	bool "Neuton (CPU)"
	help
	  Use the Neuton model. Works on all nRF Edge AI supported boards.

config NRF_EDGEAI_REGRESSION_MODEL_AXON
	bool "Axon (NPU)"
	depends on SOC_NRF54LM20B
	select NRF_AXON
	help
	  Use the Axon model. Only available on nRF54L20 (nrf54lm20b) with Axon NPU.

endchoice

config NRF_EDGEAI_REGRESSION_MODEL_OTA
	bool "Load the model from the model_storage flash partition (model-only OTA)"
	default y
	select FLASH
	select FLASH_MAP
	select CRC
	select MODEL_OTA
	select MODEL_OTA_NEUTON if NRF_EDGEAI_REGRESSION_MODEL_NEUTON
	select MODEL_OTA_AXON if NRF_EDGEAI_REGRESSION_MODEL_AXON
	help
	  When enabled (the default), this sample does not ship a compiled-in model: it loads,
	  validates, and periodically reloads a model package - matching the backend selected
	  above - from the model_storage flash partition at runtime instead (see
	  doc/libraries/model_ota.rst). Disable this to restore this sample's original
	  pre-model-OTA behavior: the selected backend's model is compiled directly into the
	  application image, and the 29 test cases are validated once at boot (asserting on the
	  expected accuracy) instead of being reloaded periodically from flash.

endmenu

source "Kconfig.zephyr"
