mainmenu "Hello Edge Impulse sample application"

config EDGE_IMPULSE_MODEL_PATH
	string "Edge Impulse model deployment path"
	default 'ei_model_nrf_accel_sim_cpu_v55.zip'
	help
	  Specifies local file path of an archive containing Edge Impulse model deployment.
	  It can be either C++ Library, Zephyr library or Axon Library deployment.

config HELLO_EI_DATA_BUF_SIZE
	int "Size of input data buffer"
	default 512
	help
	  The buffer is used to store input data for the Edge Impulse library.
	  Size of the buffer is expressed as number of floats.

# This must be at the end to include Zephyr's Kconfig tree
source "Kconfig.zephyr"
