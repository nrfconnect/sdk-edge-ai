/*
 * Model-only OTA: repurpose the unused (no-MCUboot) slot1_partition region as dedicated
 * model_storage partitions (three Neuton models + five Axon models, including the Edge AI Lab
 * wakeword/classification/regression solutions' Axon backends).
 * -DEXTRA_CONF_FILE=overlay-ota.conf; harmless (just reserved, unused flash) otherwise.
 *
 * The OTA build emits a standalone <name>_model_partition.hex per model (linked at the matching
 * partition base). Flash one into its partition without disturbing the app or the other models:
 *   nrfutil device program --firmware gear_anomaly_model_partition.hex \
 *       --options chip_erase_mode=ERASE_RANGES_TOUCHED_BY_FIRMWARE,reset=RESET_SYSTEM
 */
/delete-node/ &slot1_partition;

&cpuapp_rram {
	partitions {
		model_anomaly_storage: partition@102000 {
			compatible = "zephyr,mapped-partition";
			label = "model_anomaly_storage";
			reg = <0x102000 DT_SIZE_K(32)>;
		};

		model_classif_storage: partition@10a000 {
			compatible = "zephyr,mapped-partition";
			label = "model_classif_storage";
			reg = <0x10a000 DT_SIZE_K(32)>;
		};

		model_regress_storage: partition@112000 {
			compatible = "zephyr,mapped-partition";
			label = "model_regress_storage";
			reg = <0x112000 DT_SIZE_K(32)>;
		};

		model_person_det_storage: partition@11a000 {
			compatible = "zephyr,mapped-partition";
			label = "model_person_det_storage";
			reg = <0x11a000 DT_SIZE_K(256)>;
		};

		model_okay_nordic_storage: partition@15a000 {
			compatible = "zephyr,mapped-partition";
			label = "model_okay_nordic_storage";
			reg = <0x15a000 DT_SIZE_K(128)>;
		};

		model_wakeword_storage: partition@17a000 {
			compatible = "zephyr,mapped-partition";
			label = "model_wakeword_storage";
			reg = <0x17a000 DT_SIZE_K(64)>;
		};

		model_classif_axon_storage: partition@18a000 {
			compatible = "zephyr,mapped-partition";
			label = "model_classif_axon_storage";
			reg = <0x18a000 DT_SIZE_K(32)>;
		};

		model_regress_axon_storage: partition@192000 {
			compatible = "zephyr,mapped-partition";
			label = "model_regress_axon_storage";
			reg = <0x192000 DT_SIZE_K(32)>;
		};
	};
};
