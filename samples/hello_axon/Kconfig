source "Kconfig.zephyr"

menu "Hello Axon"

config ASYNC_INFERENCE
	bool "Run inference asynchronously"
	default y

config AVOID_INPUT_DOUBLE_BUFFER
	bool "Avoid double buffer of input data in synchronous inference mode"
	depends on !ASYNC_INFERENCE
	default y

endmenu
